{
  "name": "memento-memory",
  "version": "0.3.0",
  "type": "module",
  "description": "Persistent semantic memory for Claude Code — auto-captures context, survives compaction, zero-config recall",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./browser": "./dist/browser.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "memento": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc && tsup",
    "build:browser": "tsup",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@xenova/transformers": "^2.17.2",
    "chromadb": "^1.9.2",
    "chromadb-default-embed": "^2.13.2",
    "idb": "^8.0.3",
    "uuid": "^11.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/uuid": "^10.0.0",
    "fake-indexeddb": "^6.2.5",
    "tsup": "^8.5.1",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
