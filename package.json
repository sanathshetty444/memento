{
  "name": "memento-memory",
  "version": "0.3.0",
  "type": "module",
  "description": "Persistent semantic memory for Claude Code — auto-captures context, survives compaction, zero-config recall",
  "author": "Sanath Shetty <sanath@browserstack.com>",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sanathshetty444/memento.git"
  },
  "homepage": "https://github.com/sanathshetty444/memento#readme",
  "bugs": {
    "url": "https://github.com/sanathshetty444/memento/issues"
  },
  "keywords": [
    "claude",
    "claude-code",
    "mcp",
    "memory",
    "semantic-memory",
    "vector-search",
    "embeddings",
    "context",
    "ai-tools",
    "llm",
    "rag",
    "model-context-protocol"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js"
    }
  },
  "files": [
    "dist",
    "skills",
    "plugin.json",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "memento": "dist/cli.js",
    "memento-memory": "dist/cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc && tsup",
    "build:browser": "tsup",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build",
    "prepare": "husky",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write --no-error-on-unmatched-pattern 'src/**/*.ts' 'tests/**/*.ts' '*.json' '*.yml'",
    "format:check": "prettier --check --no-error-on-unmatched-pattern 'src/**/*.ts' 'tests/**/*.ts' '*.json' '*.yml'"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@xenova/transformers": "^2.17.2",
    "idb": "^8.0.3",
    "uuid": "^11.1.0",
    "zod": "^3.23.0"
  },
  "optionalDependencies": {
    "chromadb": "^1.9.2",
    "chromadb-default-embed": "^2.13.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "fake-indexeddb": "^6.2.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.57.1",
    "vitest": "^3.1.0"
  }
}
